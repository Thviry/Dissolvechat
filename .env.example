# Dissolve Relay — Environment Variables
# =========================================================
# Copy this file to .env and fill in values:
#   cp .env.example .env
#   nano .env
#
# Then start the stack:
#   docker compose up -d --build
#
# IMPORTANT: Variables prefixed with VITE_ are baked into the
# React client bundle at BUILD time. After changing them, you
# must rebuild the client image:
#   docker compose up --build
# =========================================================

# ── Required ──────────────────────────────────────────────

# Your publicly accessible domain name (must match your SSL certificate)
# Used for CORS — the relay will reject requests from other origins in production
# Security: if unset in production, the relay defaults to no CORS restriction,
#           which allows any origin to interact with your relay (unsafe in prod)
# Example: ALLOWED_ORIGIN=https://chat.example.com
ALLOWED_ORIGIN=https://yourdomain.com

# Relay HTTP base URL — baked into the React client bundle at BUILD time
# Must be the public HTTPS URL of your domain (no trailing slash)
# After changing this value, you must rebuild: docker compose up --build
# Example: VITE_API_URL=https://chat.example.com
VITE_API_URL=https://yourdomain.com

# ── Optional (defaults shown) ─────────────────────────────

# Internal port the relay listens on inside the Docker network
# Do NOT expose this port to the internet — nginx proxies it internally
# Valid range: 1024–65535 | Default: 3001
PORT=3001

# Node environment — MUST be "production" in production
# Controls access to the /debug/state diagnostic endpoint
# Security: if not set to "production", the relay's full internal state
#           (all registered handles, capabilities, inbox contents) is publicly
#           readable at /debug/state — set this to "production" always
NODE_ENV=production

# Path inside the relay container where the directory database is stored
# The relay-data Docker volume is mounted at /data for persistence across restarts
# Default (in-container): directory.json (relative to CWD — not persisted without a volume)
# Recommended: /data/directory.json (persisted via the relay-data volume in docker-compose.yml)
DIRECTORY_FILE=/data/directory.json

# ── Reference (not used directly — derived from VITE_API_URL at runtime) ──────

# The WebSocket URL is automatically derived from VITE_API_URL by the client code:
#   wss://yourdomain.com/ws  (replaces http→ws and appends /ws)
# You do NOT need to set this separately. Documented here for reference only.
# VITE_WS_URL=wss://yourdomain.com/ws
